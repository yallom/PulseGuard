{
  "name": "pulseguard",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "docker compose down && docker compose up -d",
    "down": "docker compose down",
    "watch-backend": "docker logs -f pulseguard_backend",
    "watch-web": "docker logs -f pulseguard_web",
    "watch-mobile": "docker logs -f pulseguard_mobile",
    "watch-db": "docker logs -f pulseguard_db",
    "logs": "docker compose logs -f --tail=50"
  },
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
